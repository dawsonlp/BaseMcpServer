# Jira Helper MCP Server Configuration
# Copy this file to config.yaml and fill in your Atlassian details.

server:
  name: jira-helper-server
  host: 0.0.0.0
  port: 7501
  log_level: INFO

# Which instance is used when a tool call doesn't name one.
# If omitted, an instance named "primary" is used, else the first instance.
default_jira_instance: primary

# One entry per Atlassian site. Each may have a `jira` and/or a `confluence`
# block. Create an API token at
# https://id.atlassian.com/manage-profile/security/api-tokens
instances:
  primary:
    description: Primary Atlassian site
    jira:
      url: https://your-domain.atlassian.net
      username: your.email@example.com
      api_token: YOUR_API_TOKEN_HERE
    confluence:
      url: https://your-domain.atlassian.net/wiki
      username: your.email@example.com
      api_token: YOUR_API_TOKEN_HERE

  # Add more sites as needed:
  # work:
  #   jira:
  #     url: https://your-company.atlassian.net
  #     username: you@company.com
  #     api_token: YOUR_WORK_API_TOKEN
